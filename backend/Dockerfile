# Backend (calc_core + FastAPI). Многоступенчатость не нужна — образ компактный.
FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# Системные зависимости (сборка argon2/psycopg).
RUN apt-get update \
    && apt-get install -y --no-install-recommends build-essential libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Исходники приложения и установка пакета с прод-зависимостями.
COPY . .
RUN pip install --upgrade pip && pip install ".[prod]"

# Непривилегированный пользователь.
RUN useradd -m appuser
USER appuser

EXPOSE 8000

# Применить миграции и запустить API.
CMD ["sh", "-c", "alembic upgrade head && uvicorn app.main:app --host 0.0.0.0 --port 8000"]

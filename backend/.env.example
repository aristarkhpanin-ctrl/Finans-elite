# Пример переменных окружения backend. Скопируйте в .env и заполните.

# База данных (SQLAlchemy URL). Локально — SQLite; в проде — PostgreSQL.
# DATABASE_URL=sqlite:///./backend_dev.db
DATABASE_URL=postgresql+psycopg://finans:finans@localhost:5432/finans

# JWT
JWT_SECRET=change-me-in-production
JWT_TTL_SECONDS=86400

# ЮKassa (если не заданы — используется ручной провайдер без реальных платежей)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_VAT_CODE=1
